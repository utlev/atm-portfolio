# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version  # keep commit-able if you want version pinning; remove this line then

# -----------------------------------------------------------------------------
# uv / poetry / pip
# -----------------------------------------------------------------------------
uv.lock  # decide per repo; commit it if you want reproducible envs
# poetry.lock  # (keep this commented — you probably want to commit it)

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_meta

# -----------------------------------------------------------------------------
# Data files — OpenSky dumps get large fast.
# Commit small samples explicitly with `git add -f path/to/sample.csv`.
# -----------------------------------------------------------------------------
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.nc
*.pickle
*.pkl
*.npz
data/raw/
data/interim/
data/processed/
!**/data/sample/**  # whitelist: committed sample data under any data/sample/

# -----------------------------------------------------------------------------
# traffic library cache (can be huge)
# -----------------------------------------------------------------------------
.traffic-cache/
**/cache/

# -----------------------------------------------------------------------------
# OS / editor
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Secrets — never commit credentials
# -----------------------------------------------------------------------------
.env
.env.local
secrets.yaml
credentials.json
**/opensky_creds*

# -----------------------------------------------------------------------------
# Tooling
# -----------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
